{
  "name": "@antdv-next/pro",
  "type": "module",
  "version": "1.0.0",
  "description": "Ant Design Vue3 Pro component library",
  "author": {
    "email": "aibayanyu@gamil.com",
    "name": "aibayanyu20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antdv-next/antdv-next.git",
    "directory": "packages/pro"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./web-types.json": "./web-types.json",
    "./web-tags.json": "./web-tags.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "package.json",
    "web-tags.json",
    "web-types.json"
  ],
  "contributes": {
    "html": {
      "customData": [
        "./web-tags.json"
      ]
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "typecheck": "vue-tsc --project tsconfig.json --noEmit",
    "build": "run-s build:web-types build:esm",
    "build:web-types": "tsx ./scripts/build-web-types.ts",
    "build:esm": "tsdown",
    "dev": "tsdown --watch",
    "prepublish": "pnpm build",
    "bump": "bumpp --commit \"chore(release): @antdv-next/pro %s\" --push --tag \"@antdv-next/pro@%s\""
  },
  "peerDependencies": {
    "vue": ">=3.2.0"
  },
  "dependencies": {
    "antdv-next": "workspace:^"
  },
  "web-types": "web-types.json"
}
